  "principles": [
    {
      "id": "drawn-magic",
      "displayName": "Drawn Magic",
      "summary": "Magic is performed by drawing spell diagrams with special ink. The emulator models this as stroke parsing, symbol recognition, and compilation."
    },
    {
      "id": "ring-activation",
      "displayName": "Ring Activation",
      "summary": "A spell activates when its diagram becomes complete, usually by closing the ring. Open rings can be prepared and diagnosed before activation."
    },
    {
      "id": "inscription-quality",
      "displayName": "Inscription Quality",
      "summary": "Size and neatness matter. The emulator turns ring, sigil, sign, and unknown-mark quality into spell quality, stability, duration, and scale."
    },
    {
      "id": "compound-rings",
      "displayName": "Compound Rings",
      "summary": "A spell can wrap or combine rings to merge effects. The emulator treats extra circles as secondary rings whose symbols contribute to one compound spell."
    },
    {
      "id": "mixed-sigils",
      "displayName": "Mixed Sigils",
      "summary": "Some spells use two or more sigils. The emulator compiles additional recognized sigils into weighted element blends instead of rejecting them."
    },
    {
      "id": "forbidden-safety",
      "displayName": "Forbidden Safety",
      "summary": "Forbidden magic includes effects on living bodies and reality-warping or highly dangerous effects. The emulator lists these as lore only and does not attempt to simulate body-targeting magic."
    }
  ],
